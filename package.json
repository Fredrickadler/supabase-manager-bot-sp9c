{
  "name": "supabase-manager-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Telegram bot for managing Supabase accounts and projects",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "webhook:set": "tsx scripts/setWebhook.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "telegraf": "^4.16.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "axios": "^1.7.7",
    "winston": "^3.14.2",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "tsx": "^4.19.1",
    "prisma": "^5.20.0",
    "@types/node": "^20.16.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "prettier": "^3.3.3",
    "@vercel/node": "^3.2.9"
  }
}
