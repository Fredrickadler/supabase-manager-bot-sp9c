# ===== Telegram =====
BOT_TOKEN=123456:ABC-your-telegram-bot-token
# Public URL of your Vercel deployment, e.g. https://your-app.vercel.app
WEBHOOK_URL=https://your-app.vercel.app
# Secret path segment to protect the webhook endpoint
WEBHOOK_SECRET=change-this-to-a-random-string

# ===== Database (Supabase Postgres used as the BOT's own database) =====
# Use Supabase's connection string (Session pooler recommended for serverless)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres?pgbouncer=true

# ===== Security =====
# 32-byte (64 hex chars) key used for AES-256-GCM encryption of stored tokens
ENCRYPTION_KEY=replace-with-64-char-hex-string

# ===== Admin =====
# Comma separated Telegram numeric user IDs allowed to access the admin panel
ADMIN_IDS=111111111,222222222

# ===== Rate limiting =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ===== Environment =====
NODE_ENV=production
